{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "plugins/graphify.js"
    // "oh-my-openagent@latest",
    // "opencode-antigravity-auth@latest",
  ],
  // === MODELS ===
  "model": "litellm/tier-fast",
  "small_model": "litellm/tier-fast",
  "autoupdate": true,
  // === FORMATTER ===
  "formatter": {
    "biome": {
      "command": [
        "npx",
        "biome",
        "format",
        "--write",
        "$FILE"
      ],
      "extensions": [
        ".js",
        ".jsx",
        ".ts",
        ".tsx",
        ".json",
        ".jsonc"
      ]
    },
    "prettier": {
      "command": [
        "npx",
        "prettier",
        "--write",
        "$FILE"
      ],
      "extensions": [
        ".md",
        ".mdx",
        ".yaml",
        ".yml",
        ".css",
        ".scss"
      ]
    }
  },
  // === PERMISSIONS ===
  "permission": {
    "read": {
      ".env": "allow",
      ".env.*": "allow",
      ".env-*": "allow"
    },
    "external_directory": "allow",
    "bash": {
      "git push": "allow",
      "git push *": "allow",
      "sudo *": "deny",
      "rm -rf /": "deny",
      "rm -rf /*": "deny",
      "rm -rf ~": "deny",
      "rm -rf ~/*": "deny",
      ":(){:|:&};:": "deny"
    }
  },
  // === MCP ===
  "mcp": {
    "next-devtools": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "next-devtools-mcp@latest"
      ]
    },
    "chrome-devtools": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "chrome-devtools-mcp@latest"
      ]
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    },
    "fetch": {
      "type": "local",
      "command": [
        "uvx",
        "mcp-server-fetch"
      ]
    }
  },
  // === AGENTS ===
  "agent": {
    "build": {
      "model": "litellm/tier-balanced",
      "temperature": 0.3
    },
    "plan": {
      "model": "litellm/tier-balanced",
      "temperature": 0.1,
      "tools": {
        "write": false,
        "edit": false,
        "patch": false
      }
    },
    "security": {
      "model": "litellm/tier-balanced",
      "temperature": 0.1,
      "tools": {
        "write": false,
        "edit": false,
        "patch": false
      }
    },
    "test-writer": {
      "model": "litellm/tier-fast",
      "temperature": 0.2,
      "permission": {
        "write": {
          "**/*.test.ts": "allow",
          "**/*.spec.ts": "allow",
          "**/*.test.tsx": "allow",
          "**/*.spec.tsx": "allow",
          "*": "deny"
        }
      }
    },
    "docs": {
      "model": "litellm/tier-fast",
      "temperature": 0.3,
      "permission": {
        "write": {
          "**/*.md": "allow",
          "**/*.mdx": "allow",
          "*": "deny"
        }
      }
    }
  },
  // === PROVIDER ===
  "provider": {
    "litellm": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Homelab Gateway",
      "options": {
        "baseURL": "https://litellm.gauravahuja.dev/v1"
      },
      "models": {
        "tier-fast": {
          "name": "⚡ Fast (Free-first)"
        },
        "tier-balanced": {
          "name": "🧠 Balanced (Smart routing)"
        },
        "tier-cheap": {
          "name": "💸 Cheap (Paid fallback)"
        }
      }
    },
    "google": {
      "models": {
        "antigravity-gemini-3-pro": {
          "name": "Gemini 3 Pro (Antigravity)",
          "limit": {
            "context": 1048576,
            "output": 65535
          },
          "modalities": {
            "input": [
              "text",
              "image",
              "pdf"
            ],
            "output": [
              "text"
            ]
          }
        }
      }
    }
  }
}
