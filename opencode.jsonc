{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "plugins/graphify.js"
  ],
  // === MODELS ===
  "model": "litellm/tier-fast",
  "small_model": "litellm/tier-fast",
  "autoupdate": true,
  // === FORMATTER ===
  "formatter": {
    "biome": {
      "command": [
        "npx",
        "biome",
        "format",
        "--write",
        "$FILE"
      ],
      "extensions": [
        ".js",
        ".jsx",
        ".ts",
        ".tsx",
        ".json",
        ".jsonc"
      ]
    },
    "prettier": {
      "command": [
        "npx",
        "prettier",
        "--write",
        "$FILE"
      ],
      "extensions": [
        ".md",
        ".mdx",
        ".yaml",
        ".yml",
        ".css",
        ".scss"
      ]
    }
  },
  // === PERMISSIONS ===
  "permission": {
    "read": {
      ".env": "allow",
      ".env.*": "allow",
      ".env-*": "allow"
    },
    "external_directory": "allow",
    "bash": {
      "git push": "allow",
      "git push *": "allow",
      "sudo *": "deny",
      "rm -rf /": "deny",
      "rm -rf /*": "deny",
      "rm -rf ~": "deny",
      "rm -rf ~/*": "deny",
      ":(){:|:&};:": "deny"
    }
  },
  // === MCP ===
  "mcp": {
    "chrome-devtools": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "chrome-devtools-mcp@latest"
      ]
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    },
    "fetch": {
      "type": "local",
      "command": [
        "uvx",
        "mcp-server-fetch"
      ]
    }
  },
  // === AGENTS ===
  "agent": {
    "build": {
      "model": "deepseek/deepseek-reasoner",
      "temperature": 0.2
    },
    "plan": {
      "model": "deepseek/deepseek-reasoner",
      "temperature": 0.1,
      "tools": {
        "write": false,
        "edit": false,
        "patch": false
      }
    },
    "test-writer": {
      "model": "deepseek/deepseek-chat",
      "temperature": 0.2,
      "permission": {
        "write": {
          "**/*.test.ts": "allow",
          "**/*.spec.ts": "allow",
          "**/*.test.tsx": "allow",
          "**/*.spec.tsx": "allow",
          "*": "deny"
        }
      }
    },
    "figma-parse": {
      "model": "deepseek/deepseek-chat",
      "temperature": 0.1,
      "maxSteps": 20,
      "system": "You are a Figma design extraction agent. Your task is to analyze Figma JSON and extract structured semantic UI information for downstream AI systems. Never generate frontend code. Never explain your reasoning unless explicitly asked. Always prefer compact structured JSON outputs over prose. Preserve semantic layout meaning, reusable components, design tokens, responsive behavior, asset references, and screen intent. Minimize noise. Ignore irrelevant Figma metadata. Prefer code recreation over asset export whenever possible."
    },
    "lovable-prompt": {
      "model": "deepseek/deepseek-chat",
      "temperature": 0.3,
      "maxSteps": 10,
      "system": "You are a Lovable prompt generation agent. Your task is to convert structured design intelligence into concise, implementation-focused prompts optimized for Lovable. Focus on responsive layout, reusable components, design systems, interactions, and proper asset usage. Never include raw Figma JSON. Never describe irrelevant implementation details. Optimize for modern React/Tailwind applications."
    },
    "docs": {
      "model": "deepseek/deepseek-chat",
      "temperature": 0.3,
      "permission": {
        "write": {
          "**/*.md": "allow",
          "**/*.mdx": "allow",
          "*": "deny"
        }
      }
    },
    "security": {
      "model": "deepseek/deepseek-chat",
      "temperature": 0.1,
      "tools": {
        "write": false,
        "edit": false,
        "patch": false
      }
    }
  },
  // === PROVIDER ===
  "provider": {
    "deepseek": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "DeepSeek",
      "options": {
        "baseURL": "https://api.deepseek.com/v1",
        "apiKey": "{env:DEEPSEEK_API_KEY}"
      },
      "models": {
        "deepseek-v4-flash": {
          "name": "⚡ DeepSeek V4 Flash"
        },
        "deepseek-v4-pro": {
          "name": "🧠 DeepSeek V4 Pro"
        }
      }
    },
    "windsurf": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Windsurf",
      "options": {
        "baseURL": "http://127.0.0.1:42100/v1"
      },
      "models": {
        "swe-1.6": {
          "name": "SWE 1.6"
        },
        "kimi-k2.6": {
          "name": "Kimi K2.6"
        }
      }
    },
    "litellm": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Homelab Gateway",
      "options": {
        "baseURL": "https://litellm.gauravahuja.dev/v1"
      },
      "models": {
        "tier-fast": {
          "name": "⚡ Fast (Free-first)"
        },
        "tier-balanced": {
          "name": "🧠 Balanced (Smart routing)"
        },
        "tier-cheap": {
          "name": "💸 Cheap (Paid fallback)"
        }
      }
    },
    "google": {
      "models": {
        "antigravity-gemini-3-pro": {
          "name": "Gemini 3 Pro (Antigravity)",
          "limit": {
            "context": 1048576,
            "output": 65535
          },
          "modalities": {
            "input": [
              "text",
              "image",
              "pdf"
            ],
            "output": [
              "text"
            ]
          }
        }
      }
    }
  }
}
